{% extends "_base.html.twig" %}

{% block title %}Home{% endblock %}

{% block header %}
    <h1>IPdb</h1>
    <p>You are accessing from <code>{{ remoteIp }}</code></p>
{% endblock %}

{% block content %}
    <section>
        <h2>Search</h2>
        <form action="info" method="get">
            <label for="search-ip-box" class="hidden">IP Address</label>
            <input type="text" id="search-ip-box" name="q" placeholder="IP Address">
            <input type="submit" value="Search">
        </form>
    </section>

    <section>
        <h2>Services</h2>
        <ul>
            <li><a href="atk/">Attacker List</a> (<a href="atk/list">Full list</a>)</li>
        </ul>
    </section>
{% endblock %}
